gWhenOutOfStock":271,"followUpProducts":2932,"deliveryDate":2933,"webname":2634,"matchingVariants":2934,"ean":2938,"title":2939,"category":6,"preOrderVip":271,"description":2643},"67a4567d8ea4cb00064a7c69","2399.0","13.0","56322338357635",{"filename":2910,"alt":2911,"provider":2677},"https://cdn.boards-and-more.com/system/product_picture_gallery_pictures/files/6836/c3fc/44c3/2d01/2b49/7ccc/original/DICE26_SLS_CC06_-_PP1.png?1748419541","Dice SLS - C06:green/heron",{"handle":8,"articleNumber":9,"color":2640,"size":2907,"variantId":2908},[2914,2917,2921,2925],{"filename":2910,"alt":2915,"provider":2677,"category":2682,"id":2916,"gender":463,"isSampleImage":271},"Duotone_Kiteboarding_Dice-SLS_Product-Pictures_5","67a4567d8ea4cb00064a7c69-picture0",{"filename":2918,"alt":2919,"provider":2677,"category":2682,"id":2920,"gender":463,"isSampleImage":271},"https://cdn.boards-and-more.com/system/product_picture_gallery_pictures/files/685e/eaa9/83c2/ca01/0219/d133/original/DICE26_SLS_CC06_-_SIDE_2.png?1751050886","Duotone_Kiteboarding_Dice-SLS_Product-Pictures_19","67a4567d8ea4cb00064a7c69-picture1",{"filename":2922,"alt":2923,"provider":2677,"category":2682,"id":2924,"gender":463,"isSampleImage":271},"https://cdn.boards-and-more.com/system/product_picture_gallery_pictures/files/685e/eaa9/83c2/ca01/2a19/d130/original/DICE26_SLS_CC06_-_PP3.png?1751050887","Duotone_Kiteboarding_Dice-SLS_Product-Pictures_20","67a4567d8ea4cb00064a7c69-picture2",{"filename":2926,"alt":2927,"provider":2677,"category":2682,"id":2928,"gender":463,"isSampleImage":271},"https://cdn.boards-and-more.com/system/product_picture_gallery_pictures/files/685e/eaaa/83c2/ca01/1619/d130/original/DICE26_SLS_CC06_-_BOTTOM.png?1751050886","Duotone_Kiteboarding_Dice-SLS_Product-Pictures_21","67a4567d8ea4cb00064a7c69-picture3",[2907],[],"Z2lkOi8vc2hvcGlmeS9Qcm9kdWN0VmFyaWFudC81NjMyMjMzODM1NzYzNQ==",[],"2026-05-15",[2935,2936,2937],{"article_number":2705,"ean":2736},{"article_number":2708,"ean":2709},{"article_number":2711,"ean":2712},"9010583287140","C06:green/heron / 13.0","Duotone Kiteboarding",[2942,2948],{"fullName":2943,"text":2944,"image":2945},"Edgar Ulrich","For me, the Dice SLS is the most versatile sporty kite out there, and it makes every session the most fun! Whether I’m hitting hardcore Freestyle tricks, going for Big Air, or even riding in the waves, this kite allows me to do it all with incredible power and precision. The performance is insane, and I can confidently push my limits in any condition. The Dice SLS truly delivers a thrilling experience on the water, no matter what style I'm riding!",{"filename":2946,"alt":2947,"provider":2677},"https://cdn.boards-and-more.com/system/product_quotes/pictures/68ac/62df/66d9/0d00/c432/047b/medium/Duotone-Kiteboarding-Edgar-Ulrich.png?1756127962","Quote Edgar Ulrich",{"fullName":2949,"text":2950,"image":2951},"Paula Novotna","The Dice SLS is my go-to kite for “I want do do it all” sessions because it offers amazing versatility and fun! Whether I'm pushing my limits with freestyle moves, going big, or exploring some waves, this kite delivers incredible power and responsiveness. I love how it responds to my every command, helping me perform with confidence and style. The Dice SLS truly amplifies my riding experience no matter the conditions!",{"filename":2952,"alt":2953,"provider":2677},"https://cdn.boards-and-more.com/system/product_quotes/pictures/68ac/62ed/66d9/0d00/d832/047b/medium/Duotone-Kiteboarding-Paula-Novotna.png?1756128094","Quote Paula Novotna",[],[2956],{"videoId":2957,"image":463,"type":2958,"category":2959},"h_Pf73RqpkA","youtube","Product Video",[2961,2967,2973,2979,2985,2991,2997,3003,3009],{"id":2962,"colors":2963,"sizes":2964,"filename":2965,"alt":2966,"provider":2677},"action-shot0",[2636,2637,2638,2639,2640],[2672,2744,2811,2834,2771,2697,2872,2907],"https://cdn.boards-and-more.com/system/product_picture_gallery_pictures/files/68ae/c0bc/59f1/b36d/509c/692f/original/Website-22_DTK-Duotone-DiceSLS-NoeFont-