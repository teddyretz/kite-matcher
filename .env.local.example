# Anthropic — required for scripts/process-reviews.ts
ANTHROPIC_API_KEY=sk-ant-...

# Site URL — used for canonical URLs, OG images, sitemap.
# Defaults to https://kitematch.com if unset. Override per environment.
NEXT_PUBLIC_SITE_URL=https://kitematch.com

# Supabase (optional — enables user review submission)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
